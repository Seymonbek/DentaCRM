# DentaCRM frontend env — copy to .env.local for local dev.
# NEVER commit real secrets. Values here are safe defaults.

# Base URL of the backend API (used by Axios when running outside the Vite
# dev proxy — e.g. `npm run preview`). In dev the Vite proxy handles /api
# transparently, so this can stay empty.
VITE_API_URL=/api/v1

# When running the Vite dev server outside docker-compose you may need to
# proxy to a different host — override this in .env.local:
# VITE_API_PROXY_TARGET=http://localhost:8000
VITE_API_PROXY_TARGET=http://backend:8000

# Session storage strategy for the refresh token.
#   memory (default) → refresh kept only in memory + httpOnly cookie later
#   local            → dev-only fallback that persists across reloads
VITE_REFRESH_STORAGE=memory
