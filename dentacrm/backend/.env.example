# =============================================================================
# Backend-only .env.example (development).
#
# The canonical .env lives at dentacrm/.env (loaded by docker-compose).
# manage.py also auto-loads this file when developers run Django outside
# Docker (see manage.py — python-dotenv is optional).
# =============================================================================

DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=insecure-dev-key-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://dentacrm:dentacrm@localhost:5432/dentacrm

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# Object storage
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_MEDIA=dentacrm-media
S3_BUCKET_BACKUPS=dentacrm-backups

# Telegram
TELEGRAM_BOT_TOKEN=
