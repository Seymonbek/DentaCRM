# =============================================================================
# DentaCRM — environment variables (PRODUCTION template).
#
# Copy to `.env` alongside docker-compose.prod.yml and replace every
# placeholder with a real value. NEVER commit the resulting `.env`.
# =============================================================================

# ---- Django ----------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.prod
# Generate a real 50+ character random string:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=REPLACE_ME_WITH_A_LONG_RANDOM_STRING
DJANGO_DEBUG=0
# Comma-separated. Include every DNS name that will terminate at nginx.
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
DJANGO_CORS_ALLOWED_ORIGINS=https://example.com
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_LOG_LEVEL=WARNING

# ---- PostgreSQL ------------------------------------------------------------
POSTGRES_DB=dentacrm
POSTGRES_USER=dentacrm
POSTGRES_PASSWORD=REPLACE_ME_WITH_A_STRONG_DB_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://dentacrm:REPLACE_ME_WITH_A_STRONG_DB_PASSWORD@postgres:5432/dentacrm

# ---- Redis / Celery --------------------------------------------------------
# Set REDIS_PASSWORD to a strong secret; the same value is included in the
# URLs below so Django/Celery authenticate against the requirepass'd redis.
REDIS_PASSWORD=REPLACE_ME_WITH_A_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:REPLACE_ME_WITH_A_STRONG_REDIS_PASSWORD@redis:6379/0
CELERY_BROKER_URL=redis://:REPLACE_ME_WITH_A_STRONG_REDIS_PASSWORD@redis:6379/1
CELERY_RESULT_BACKEND=redis://:REPLACE_ME_WITH_A_STRONG_REDIS_PASSWORD@redis:6379/2
CELERY_LOG_LEVEL=INFO
CELERY_CONCURRENCY=4

# ---- Object storage (managed S3 recommended; MinIO profile for on-prem) ----
# For AWS S3: leave S3_ENDPOINT_URL empty (django-storages will use AWS).
# For MinIO/self-hosted: set S3_ENDPOINT_URL=https://s3.yourhost.com and
# enable the "minio" compose profile: `--profile minio` on `up`.
S3_ENDPOINT_URL=
S3_ACCESS_KEY=REPLACE_ME_WITH_S3_ACCESS_KEY
S3_SECRET_KEY=REPLACE_ME_WITH_S3_SECRET_KEY
S3_BUCKET_MEDIA=dentacrm-media
S3_BUCKET_BACKUPS=dentacrm-backups
S3_REGION=us-east-1

# ---- JWT -------------------------------------------------------------------
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ---- Telegram bot ----------------------------------------------------------
TELEGRAM_BOT_TOKEN=REPLACE_ME_WITH_BOT_TOKEN
# If you want webhook mode instead of polling, set the public HTTPS URL:
TELEGRAM_WEBHOOK_URL=

# ---- Sentry (optional) ------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# ---- Gunicorn tuning -------------------------------------------------------
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
GUNICORN_LOG_LEVEL=info

# ---- Frontend (baked into bundle at build-time) ----------------------------
# For same-origin deployments (nginx proxies /api → backend) keep this.
VITE_API_URL=/api/v1
VITE_REFRESH_STORAGE=memory

# ---- Host ingress port -----------------------------------------------------
# The only container published to the host. Put a real TLS-terminating
# reverse proxy (Caddy/Cloudflare/AWS ALB) in front of this for HTTPS.
HOST_HTTP_PORT=80

# ---- Backups ---------------------------------------------------------------
DB_BACKUPS_ENABLED=1
DB_BACKUPS_DIR=/app/media/backups
