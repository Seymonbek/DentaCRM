# =============================================================================
# DentaCRM — environment variables (PRODUCTION template).
#
# Copy to `.env` alongside docker-compose.prod.yml and replace every
# placeholder with a real value. NEVER commit the resulting `.env`.
# =============================================================================

# ---- Django ----------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.prod
# Generate a real 50+ character random string:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=REPLACE_ME_WITH_A_LONG_RANDOM_STRING
DJANGO_DEBUG=0
# Comma-separated. Include every DNS name that will terminate at nginx.
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
DJANGO_CORS_ALLOWED_ORIGINS=https://example.com
DJANGO_SECURE_SSL_REDIRECT=1
# T128 — HSTS. 31536000 = 1 year, ships with includeSubDomains + preload
# so the site is submittable to the browser HSTS preload list. For a
# fresh staging deployment set a short lifetime (e.g. 60) so ops can
# back out of TLS without waiting a year for browser caches to expire.
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1
# T128 — cookie hardening. HttpOnly + SameSite=Lax is the safest sane
# default for a first-party API + SPA. Override to "Strict" only if you
# have no OAuth-style top-level redirects.
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_HTTPONLY=1
DJANGO_LOG_LEVEL=WARNING
# T131 — emit structured JSON logs in production so log aggregators
# (CloudWatch, Datadog, Loki, ...) can index request_id + user_id
# fields. Set to 0 to fall back to the plaintext "verbose" formatter
# during local prod-mode debugging.
DJANGO_LOG_JSON=1

# ---- PostgreSQL ------------------------------------------------------------
POSTGRES_DB=dentacrm
POSTGRES_USER=dentacrm
POSTGRES_PASSWORD=REPLACE_ME_WITH_A_STRONG_DB_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgres://dentacrm:REPLACE_ME_WITH_A_STRONG_DB_PASSWORD@postgres:5432/dentacrm

# ---- Redis / Celery --------------------------------------------------------
# Set REDIS_PASSWORD to a strong secret; the same value is included in the
# URLs below so Django/Celery authenticate against the requirepass'd redis.
REDIS_PASSWORD=REPLACE_ME_WITH_A_STRONG_REDIS_PASSWORD
REDIS_URL=redis://:REPLACE_ME_WITH_A_STRONG_REDIS_PASSWORD@redis:6379/0
CELERY_BROKER_URL=redis://:REPLACE_ME_WITH_A_STRONG_REDIS_PASSWORD@redis:6379/1
CELERY_RESULT_BACKEND=redis://:REPLACE_ME_WITH_A_STRONG_REDIS_PASSWORD@redis:6379/2
CELERY_LOG_LEVEL=INFO
CELERY_CONCURRENCY=4

# ---- Object storage (managed S3 recommended; MinIO profile for on-prem) ----
# For AWS S3: leave S3_ENDPOINT_URL empty (django-storages will use AWS).
# For MinIO/self-hosted: set S3_ENDPOINT_URL=https://s3.yourhost.com and
# enable the "minio" compose profile: `--profile minio` on `up`.
S3_ENDPOINT_URL=
S3_ACCESS_KEY=REPLACE_ME_WITH_S3_ACCESS_KEY
S3_SECRET_KEY=REPLACE_ME_WITH_S3_SECRET_KEY
S3_BUCKET_MEDIA=dentacrm-media
S3_BUCKET_BACKUPS=dentacrm-backups
S3_REGION=us-east-1

# ---- JWT -------------------------------------------------------------------
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
# T124: JWT signing key is separate from DJANGO_SECRET_KEY so JWTs and
# sessions can be rotated on independent schedules. Generate a distinct
# 50+ character random string here:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# Rotating this value invalidates every issued JWT — clients must re-login.
JWT_SIGNING_KEY=REPLACE_ME_WITH_A_DIFFERENT_LONG_RANDOM_STRING
JWT_ALGORITHM=HS256

# ---- API throttling (T118, T119) ------------------------------------------
# Rate limits for unauthenticated attack surfaces. Format: "<count>/<period>".
# Tighten in prod if a bot floods the login endpoint from a small pool of IPs;
# loosen only after adding a real WAF in front.
#   - LOGIN_RATE_LIMIT           → POST /api/v1/auth/login/
#   - PASSWORD_RESET_RATE_LIMIT  → POST /api/v1/auth/password-reset/{request,
#                                       confirm}/   (bounds OTP brute-force)
LOGIN_RATE_LIMIT=5/min
PASSWORD_RESET_RATE_LIMIT=3/hour

# ---- Response security headers (T126) --------------------------------------
# Override apps.core.middleware.SecurityHeadersMiddleware defaults ONLY when
# the deployment topology requires it. Common reasons to override:
#   * Swagger UI is served from a different CDN (default allows unpkg.com).
#   * The frontend is at a different origin than the API — add its origin
#     to connect-src.
#   * A CSP report-uri is wired up to a monitoring endpoint.
# Leave blank to use the shipped defaults (recommended).
DJANGO_CSP_POLICY=
DJANGO_PERMISSIONS_POLICY=
DJANGO_REFERRER_POLICY=same-origin

# ---- Media / photo upload limits (T130) ------------------------------------
MAX_PHOTO_MB=8

# ---- Telegram bot ----------------------------------------------------------
TELEGRAM_BOT_TOKEN=REPLACE_ME_WITH_BOT_TOKEN
# If you want webhook mode instead of polling, set the public HTTPS URL:
TELEGRAM_WEBHOOK_URL=

# ---- Sentry (optional) ------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# ---- Gunicorn tuning -------------------------------------------------------
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
GUNICORN_LOG_LEVEL=info

# ---- Frontend (baked into bundle at build-time) ----------------------------
# For same-origin deployments (nginx proxies /api → backend) keep this.
VITE_API_URL=/api/v1
VITE_REFRESH_STORAGE=memory

# ---- Host ingress port -----------------------------------------------------
# The only container published to the host. Put a real TLS-terminating
# reverse proxy (Caddy/Cloudflare/AWS ALB) in front of this for HTTPS.
HOST_HTTP_PORT=80

# ---- Backups ---------------------------------------------------------------
DB_BACKUPS_ENABLED=1
DB_BACKUPS_DIR=/app/media/backups
