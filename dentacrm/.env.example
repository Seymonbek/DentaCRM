# =============================================================================
# DentaCRM — environment variables (development)
# Copy this file to `.env` and adjust values. `.env` is git-ignored.
# =============================================================================

# ---- Django ----------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost

# ---- PostgreSQL ------------------------------------------------------------
POSTGRES_DB=dentacrm
POSTGRES_USER=dentacrm
POSTGRES_PASSWORD=dentacrm
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Full DSN used by Django (kept in sync with the vars above).
DATABASE_URL=postgres://dentacrm:dentacrm@postgres:5432/dentacrm

# ---- Redis / Celery --------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Object storage (MinIO in dev, S3 in prod) -----------------------------
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_MEDIA=dentacrm-media
S3_BUCKET_BACKUPS=dentacrm-backups
S3_REGION=us-east-1

# ---- JWT -------------------------------------------------------------------
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ---- Telegram bot ----------------------------------------------------------
# Leave blank in local dev — the bot uses a mocked sender when unset.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# ---- Frontend (Vite) -------------------------------------------------------
VITE_API_URL=http://localhost:8000/api/v1

# ---- Host port overrides (optional) ----------------------------------------
# Change these if the default ports clash with other services on your host.
HOST_POSTGRES_PORT=5432
HOST_REDIS_PORT=6379
HOST_MINIO_API_PORT=9000
HOST_MINIO_CONSOLE_PORT=9001
HOST_BACKEND_PORT=8000
HOST_FRONTEND_PORT=5173
